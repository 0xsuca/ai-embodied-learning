z`int red = 8;
int blue = 4;
int redTime = 1000;
int redTimeD = 1000;

void setup() {
    pinMode(red, OUTPUT);
    pinMode(blue, OUTPUT);
}

void loop() {
    digitalWrite(red, HIGH);
    digitalWrite(blue, LOW);
    delay(redTime);
    digitalWrite(red, LOW);
    digitalWrite(blue, HIGH);
    delay(redTimeD);




}
